# --- Server Configuration ---
PORT=3000
NODE_ENV=production

# --- Security ---
# Pastikan API_KEY ini sama dengan yang ada di config/env Laravel kalian
API_KEY=isi sesuai dengan apia di laravel kalian, pastikan sama dengan yang ada di config/env Laravel kalian

# --- Laravel Integration ---
# Ganti localhost:8000 dengan domain produksi jika sudah dideploy
LARAVEL_WEBHOOK_URL=http://127.0.0.1:8000/api/whatsapp/webhook

# --- WhatsApp Session ---
SESSION_NAME=wa-session

# --- Media Handling (Resource Management) ---
# Batas 15MB sesuai permintaan kalian
MAX_FILE_SIZE=15
# Lokasi folder temporary untuk media
TEMP_PATH=./temp

# --- Optional Reference ---
WHATSAPP_BUSINESS_PHONE=+62xxxxxxx