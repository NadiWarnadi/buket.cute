# --- Server Configuration ---
PORT=3000
NODE_ENV=production

# --- Security ---
# Pastikan API_KEY ini sama dengan yang ada di config/env Laravel 
API_KEY=your-super-secret-api-key-change-me-in-production

# --- Laravel Integration ---
# Ganti localhost:8000 dengan domain produksi jika sudah dideploy
LARAVEL_WEBHOOK_URL=http://127.0.0.1:8000/api/whatsapp/webhook

# --- WhatsApp Session ---
SESSION_NAME=wa-session

# --- Media Handling (Resource Management) ---
# Batas 15MB sesuai permintaan kalian
MAX_FILE_SIZE=15
# Lokasi folder temporary untuk media
TEMP_PATH=./temp

WHATSAPP_BUSINESS_PHONE=+62xxxxxxx

QUEUE_DB_PATH=./queue.db
QUEUE_PROCESS_INTERVAL=5000
MAX_RETRY_ATTEMPTS=5

# ===============================================
# ANTI-DETECTION STRATEGIES (Fitur Baru)
# ===============================================

# DELAY ANTAR PESAN (ms) - Simulasi kecepatan ketik manusia
# Min delay: 1000ms (1 detik) - jangan terlalu cepat
# Max delay: 5000ms (5 detik) - waktu ketik normal
MIN_MESSAGE_DELAY=1000
MAX_MESSAGE_DELAY=5000

# TYPING INDICATOR (Simulasi Pengetikan)
# Durasi pengetikan dalam ms
# Min typing: 500ms (setengah detik)
# Max typing: 3000ms (3 detik)
MIN_TYPING_TIME=500
MAX_TYPING_TIME=5000

# ENABLE FITUR ANTI-DETECTION (true/false)
# Set ke 'false' jika ingin disable sementara untuk testing
ENABLE_MESSAGE_DELAY=true
ENABLE_TYPING_INDICATOR=true
ENABLE_BROADCAST_LIMIT=true

# BATASAN BROADCAST (Jangan spam ke satu kontak)
# Maksimal pesan per kontak dalam 1 jam (3600 detik)
# Rekomendasi: 50 pesan per jam untuk broadcast campaign yang aman
# Jika lebih dari 50, risiko deteksi/blok lebih tinggi
BROADCAST_PER_HOUR=50

# Hapus job failed setelah X hari (default 2)
QUEUE_CLEANUP_DAYS=4

# Interval cleanup dalam jam (default 1)
QUEUE_CLEANUP_INTERVAL_HOURS=24

# Maksimal percobaan retry (default 5, bisa kurangi jika ingin cepat gagal)
MAX_RETRY_ATTEMPTS=5

